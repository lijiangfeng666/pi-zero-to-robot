# ============================================
# pi-zero-to-robot 配置
# 复制此文件为 .env，填入你的 API Key
# ============================================

# 百度语音识别/合成
# 申请地址：https://console.bce.baidu.com/ai/#/ai/speech/overview
BAIDU_APP_ID=你的APP_ID
BAIDU_API_KEY=你的API_KEY
BAIDU_SECRET_KEY=你的SECRET_KEY

# DeepSeek AI 对话
# 申请地址：https://platform.deepseek.com/
DEEPSEEK_KEY=你的DEEPSEEK_API_KEY

# ============================================
# 可选配置（不填则用默认值）
# ============================================

# 唤醒词（默认：土豆）
# WAKE_WORD=土豆

# 麦克风灵敏度（默认：2500，越小越灵敏）
# VAD_THRESHOLD=2500

# 麦克风增益（默认：3000，越大越灵敏）
# MIC_GAIN=3000

# 默认音量 0.0~1.0（默认：1.0）
# VOLUME=1.0

# 唤醒后录音时长秒（默认：1.5）
# WAKE_RECORD_SECONDS=1.5

# 普通指令录音时长秒（默认：2.0）
# RECORD_SECONDS=2.0

# 指令超时秒（默认：4）
# COMMAND_TIMEOUT=4
